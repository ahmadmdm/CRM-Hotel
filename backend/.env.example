APP_NAME=CrmHotel API
APP_ENV=local
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
APP_PORT=8000
DB_PORT=5432
REDIS_PORT=6379
SEED_DEMO_DATA=true
DEMO_USER_PASSWORD=ChangeMe123!
DATABASE_URL=postgresql+psycopg://crmhotel:crmhotel@db:5432/crmhotel
REDIS_URL=redis://redis:6379/0
# Extra non-loopback frontend origins. Localhost and 127.0.0.1 on any port
# are accepted automatically for local visual validation.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3004,http://localhost:3005,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:3004,http://127.0.0.1:3005,http://127.0.0.1:5173,http://127.0.0.1:8080
SUPER_ADMIN_EMAIL=admin@crmhotel.example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
